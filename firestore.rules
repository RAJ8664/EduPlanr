rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerDoc() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isOwnerCreate() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function isOwnerUpdate() {
      return isOwnerDoc()
        && request.resource.data.userId == resource.data.userId;
    }

    // User profile documents
    match /users/{userId} {
      allow create: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow update: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && userId == request.auth.uid;
    }

    // Owner-scoped collections
    match /subjects/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /semesters/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /syllabi/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /sessions/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /materials/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /routines/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /examRoutines/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /conversations/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    match /notifications/{docId} {
      allow create: if isOwnerCreate();
      allow read, delete: if isOwnerDoc();
      allow update: if isOwnerUpdate();
    }

    // Deny all other collections by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
